{
  "name": "devlet-haberleri-bot",
  "version": "0.3.0",
  "description": "devletinhaberleri.com için %100 ücretsiz WordPress otomatik haber bot",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "type-check": "tsc --noEmit",
    "test:connections": "tsx src/scripts/test-connections.ts",
    "test:scrape": "tsx src/scripts/run-scrape.ts",
    "test:full": "tsx src/scripts/test-full-pipeline.ts",
    "publish:once": "tsx src/index.ts --publish",
    "run:job": "tsx src/index.ts --job"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "@supabase/supabase-js": "^2.45.0",
    "axios": "^1.7.0",
    "cheerio": "^1.0.0",
    "dotenv": "^16.4.0",
    "rss-parser": "^3.13.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
