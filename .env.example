# =====================================================
# DEVLET HABERLERİ BOT - %100 ÜCRETSİZ STACK
# =====================================================
# Bu dosyayı .env olarak kopyala, değerleri doldur.

# ---- Genel ----
NODE_ENV=development
TIMEZONE=Europe/Istanbul
LOG_LEVEL=info

# ---- Google Gemini API (ZORUNLU - AI metin) ----
# https://aistudio.google.com/apikey
# Ücretsiz, kart gerekmez
GEMINI_API_KEY=

# ---- Pexels API (ZORUNLU - görseller) ----
# https://www.pexels.com/api/new/
# Ücretsiz, kart gerekmez (200 istek/saat, 20K/ay)
PEXELS_API_KEY=

# ---- Supabase (ZORUNLU - veritabanı) ----
# https://supabase.com → Project Settings → API
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_ANON_KEY=eyJh...
SUPABASE_SERVICE_ROLE_KEY=eyJh...

# ---- WordPress (ZORUNLU) ----
WORDPRESS_URL=https://devletinhaberleri.com
WORDPRESS_USERNAME=otomasyon
# Application Password (WP admin > Kullanıcılar > Profil)
# Boşluklarla beraber kopyala, sistem temizler
WORDPRESS_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# ---- Site / Marka ----
SITE_DOMAIN=devletinhaberleri.com
SITE_BRAND_NAME=Devlet Haberleri

# ---- Çalışma Davranışı ----
# Her tetiklemede kaç haber yayınlansın (GitHub Actions günde 2 kere tetikler)
POSTS_PER_RUN=1
